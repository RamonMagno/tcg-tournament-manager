*.user
*.suo
*.userosscache
*.sln.docstates

# Rider
.idea/
*.sln.iml

# VS Code
.vscode/

# MacOS
.DS_Store

# Linux
*~

# Logs
*.log

# Configurações locais
appsettings.Development.json

# Test results
TestResults/

# Outros arquivos temporários
*.tmp
*.temp

# Arquivos de backup
*.bak
*.old
*.orig
